PORT=4000
MONGO_URL=mongodb://localhost:27017/linkflow
JWT_SECRET=change-me-to-a-32-plus-char-secret-string
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=30
CORS_ORIGINS=moz-extension://*,chrome-extension://*
# Auth rate limit per IP per minute. Spec §10 says 10/min in production.
# Default 100 in code is dev/test friendly; tighten in prod.
PER_IP_AUTH_RATE=10
NODE_ENV=development
