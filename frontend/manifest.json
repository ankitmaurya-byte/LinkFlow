{
  "manifest_version": 3,
  "name": "LinkFlow",
  "version": "1.0.7",
    "browser_specific_settings": {
    "gecko": {
      "id": "ankitmaurya2989@gmail.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "A modern bookmark manager with folder organization and AI-powered research playground",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "unlimitedStorage",
    "bookmarks",
    "alarms",
    "tabGroups"
  ],
  "host_permissions": [
    "http://localhost:4000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "LinkFlow"
  },
  "background": {
    "scripts": [
      "lib/api.js",
      "lib/auth.js",
      "lib/storage.js",
      "lib/bookmarks-sync.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/floating.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "icons/*",
        "popup/*",
        "components/*",
        "lib/*",
        "playground/*",
        "canvas/*",
        "github/*",
        "feed/*",
        "clocks/*",
        "timer/*",
        "blogs/*",
        "newsletters/*",
        "startups/*",
        "tabs/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
